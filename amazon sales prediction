import pandas as pd
from sklearn.linear_model import LinearRegression

# load dataset
df = pd.read_csv(r"C:\Users\lavan\OneDrive\ドキュメント\amazon_sales_data 2025.csv")

# convert date to datetime
df["Date"] = pd.to_datetime(df["Date"], errors="coerce")

# extract month
df["Month"] = df["Date"].dt.month

# group by product and month
sales = df.groupby(["Product","Month"])["Quantity"].sum().reset_index()

products = sales["Product"].unique()

predictions = {}

for p in products:
    data = sales[sales["Product"] == p]

    X = data[["Month"]]
    y = data["Quantity"]

    model = LinearRegression()
    model.fit(X,y)

    pred = model.predict([[data["Month"].max()+1]])[0]
    predictions[p] = pred

print(predictions)

top_product = max(predictions, key=predictions.get)
print("Product likely to sell most next month:", top_product)
