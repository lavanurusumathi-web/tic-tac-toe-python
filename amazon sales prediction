    "import pandas as pd\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "# load dataset\n",
    "df = pd.read_csv(r\"C:\\Users\\lavan\\OneDrive\\ドキュメント\\amazon_sales_data 2025.csv\")\n",
    "\n",
    "# convert date to datetime\n",
    "df[\"Date\"] = pd.to_datetime(df[\"Date\"], errors=\"coerce\")\n",
    "\n",
    "# extract month\n",
    "df[\"Month\"] = df[\"Date\"].dt.month\n",
    "\n",
    "# group by product and month\n",
    "sales = df.groupby([\"Product\",\"Month\"])[\"Quantity\"].sum().reset_index()\n",
    "\n",
    "products = sales[\"Product\"].unique()\n",
    "\n",
    "predictions = {}\n",
    "\n",
    "for p in products:\n",
    "    data = sales[sales[\"Product\"] == p]\n",
    "\n",
    "    X = data[[\"Month\"]]\n",
    "    y = data[\"Quantity\"]\n",
    "\n",
    "    model = LinearRegression()\n",
    "    model.fit(X,y)\n",
    "\n",
    "    pred = model.predict([[data[\"Month\"].max()+1]])[0]\n",
    "    predictions[p] = pred\n",
    "\n",
    "print(predictions)\n",
    "\n",
    "top_product = max(predictions, key=predictions.get)\n",
    "print(\"Product likely to sell most next month:\", top_product)"
   ]
